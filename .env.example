# Copiá este archivo a .env y reemplazá con tu clave real.
# No subas .env a GitHub.

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend (registro/login y API de posibles clientes)
JWT_SECRET=genera_una_clave_larga_y_aleatoria_aqui
# PORT lo define Railway automáticamente; en local opcional (default 3000)

# En Railway: usar volumen persistente para que la base no se pierda en redeploys.
# Crear un Volume en el servicio con mount path /data y agregar:
# SQLITE_DB_PATH=/data/wjf.db
# SQLITE_DB_PATH opcional en local (default: data/wjf.db)

# Gemini (descripción del negocio y mensaje para el cliente). En Railway podés usar GEMINI_API_KEYS=key1,key2,key3
GEMINI_API_KEY=tu_gemini_api_key_aqui
# GEMINI_API_KEYS=key1,key2,key3  (opcional, para rotar cuota)
# GEMINI_MODEL opcional (default: gemini-2.5-flash-lite)
