# Copiá este archivo a .env y reemplazá con tu clave real.
# No subas .env a GitHub.

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Para descripciones con Gemini (panel de detalle y scripts)
GEMINI_API_KEY=your_gemini_api_key_here
# Opcional: varias keys separadas por coma para rotar (evitar cuota)
# GEMINI_API_KEYS=key1,key2,key3
# Opcional: modelo (por defecto gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite
