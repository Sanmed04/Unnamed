# Copiá este archivo a .env y reemplazá con tu clave real.
# No subas .env a GitHub.

GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Backend (registro/login y API de posibles clientes)
JWT_SECRET=genera_una_clave_larga_y_aleatoria_aqui
# PORT lo define Railway automáticamente; en local opcional (default 3000)

# Gemini (descripción del lugar para vista extendida de posibles clientes)
GEMINI_API_KEY=tu_gemini_api_key_aqui
# GEMINI_MODEL opcional (default: gemini-1.5-flash)
